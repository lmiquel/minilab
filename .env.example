# ── Pi-hole ────────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=CHANGE_MOI_pihole         # Mot de passe interface web Pi-hole

# ── WireGuard ──────────────────────────────────────────────────────────────────
WG_SERVER_URL=ton-domaine.duckdns.org     # Ton DDNS ou IP publique fixe
WG_PEERS=alice,bob,charlie                # Noms de tes amis (un fichier .conf par peer)

# ── Ragnarok Online ────────────────────────────────────────────────────────────
RO_DB_ROOT_PASSWORD=CHANGE_MOI_root
RO_DB_PASSWORD=CHANGE_MOI_ro
RO_SERVER_NAME=minilab-ro

# ── Valheim ────────────────────────────────────────────────────────────────────
VALHEIM_SERVER_NAME=minilab-valheim
VALHEIM_WORLD_NAME=minilab
VALHEIM_PASSWORD=CHANGE_MOI_valheim

# ── Discord Bot (minilab-helper) ───────────────────────────────────────────────
DISCORD_TOKEN=ton_token_bot_discord
DISCORD_OWNER_ID=ton_user_id_discord      # Clic droit sur ton profil > Copier l'identifiant
